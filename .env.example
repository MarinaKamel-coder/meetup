# ========================================================
# CONFIGURATION DE LA BASE DE DONNÉES (NEON / POSTGRES)
# ========================================================
# URL de connexion à ta base de données Neon
DATABASE_URL="postgresql://user:password@ep-host-name.aws.neon.tech/dbname?sslmode=require"

# ========================================================
# AUTHENTIFICATION (CLERK)
# ========================================================
# Clés API Clerk (récupérables sur le dashboard Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Routes de redirection pour Clerk
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/"

# Secret pour les Webhooks Clerk (Svix)
CLERK_WEBHOOK_SECRET=whsec_...

# ========================================================
# PAIEMENTS (STRIPE)
# ========================================================
# Clés API Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Secret pour le Webhook Stripe (Stripe CLI ou Dashboard)
STRIPE_WEBHOOK_SECRET=whsec_...

# ========================================================
# AUTRES CONFIGURATIONS
# ========================================================
APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000